/**
 * 8-way Or gate: 
 * out = in[0] Or in[1] Or ... Or in[7]
 */
CHIP Or8Way {
    IN in[8];
    OUT out;

    PARTS:
    Or(a=in[0], b=in[1], out=o00);
    Or(a=in[2], b=in[3], out=o01);
    Or(a=in[4], b=in[5], out=o02);
    Or(a=in[6], b=in[7], out=o03);

    Or(a=o00, b=o01, out=o10);
    Or(a=o02, b=o03, out=o11);

    Or(a=o10, b=o11, out=out);
}